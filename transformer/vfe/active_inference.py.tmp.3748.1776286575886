"""
VFEActiveInference: target-free E-step shaping via pragmatic + epistemic terms.

Injected as a callback into the E-step — does NOT contaminate the E-step code.
Both terms are folded into grad_mu/grad_sigma BEFORE Fisher projection, so all
terms share one information-geometric descent per Amari 1998.

Usage:
    ai_fn = VFEActiveInference(cfg, prior_bank) if cfg.active_inference else None
    beliefs = stack(beliefs, priors, mask, active_inference_fn=ai_fn)
"""

import math
from typing import Optional, Tuple

import torch
import torch.nn as nn

from transformer.core.active_inference import _compute_active_inference_gradient


class VFEActiveInference(nn.Module):
    r"""Target-free active inference callback for the E-step.

    Computes pragmatic (entropy minimization) and epistemic (BALD MI)
    gradients from the model's own predictive distribution, without
    any target token information.

    **Pragmatic** :math:`F_{\text{prag}} = \lambda_{\text{prag}} \sum_i H[\hat{p}_i]`:
    pushes beliefs toward confident predictions.

    **Epistemic** :math:`F_{\text{epi}} = -\lambda_{\text{epi}} \sum_i I(z_i; y_i | q_i)`:
    rewards beliefs whose predictive distribution depends on the latent,
    providing counterpressure against pragmatic entropy collapse.

    Args:
        cfg: VFEConfig with active_inference weights and samples.
        prior_bank: VFEPriorBank for KL-based readout.
    """

    def __init__(self, cfg: 'VFEConfig', prior_bank: 'VFEPriorBank') -> None:
        super().__init__()
        self.pragmatic_weight = cfg.pragmatic_weight
        self.epistemic_weight = cfg.epistemic_weight
        self.epistemic_samples = cfg.epistemic_samples
        # Use __dict__ to avoid nn.Module registering prior_bank as child
        self.__dict__['prior_bank'] = prior_bank
        self.decode_tau = cfg.decode_tau

    def forward(
        self,
        mu: torch.Tensor,
        sigma: torch.Tensor,
    ) -> Tuple[Optional[torch.Tensor], Optional[torch.Tensor]]:
        r"""Compute active inference gradients for the E-step.

        Args:
            mu: ``(B, N, K)`` current belief means.
            sigma: ``(B, N, K)`` diagonal variances or ``(B, N, K, K)`` full.

        Returns:
            ``(grad_mu, grad_sigma)`` — Euclidean gradients to be added to
            the VFE gradient sum before Fisher projection. Either may be None.
        """
        return _compute_active_inference_gradient(
            mu_current=mu,
            sigma_current=sigma,
            prior_bank=self.prior_bank,
            pragmatic_weight=self.pragmatic_weight,
            epistemic_weight=self.epistemic_weight,
            epistemic_samples=self.epistemic_samples,
            decode_tau=self.effective_decode_tau,
        )
